      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "np.random.seed(42)\n",
        "\n",
        "rows = 1000\n",
        "\n",
        "data = pd.DataFrame({\n",
        "\n",
        "    \"CGPA\":np.round(np.random.uniform(5,10,rows),2),\n",
        "\n",
        "    \"Programming\":np.random.randint(1,11,rows),\n",
        "\n",
        "    \"Aptitude\":np.random.randint(40,100,rows),\n",
        "\n",
        "    \"Communication\":np.random.randint(40,100,rows),\n",
        "\n",
        "    \"Projects\":np.random.randint(0,6,rows),\n",
        "\n",
        "    \"Internship\":np.random.randint(0,3,rows),\n",
        "\n",
        "    \"Certifications\":np.random.randint(0,6,rows)\n",
        "\n",
        "})\n",
        "\n",
        "placement=[]\n",
        "\n",
        "for i,row in data.iterrows():\n",
        "\n",
        "    score=0\n",
        "\n",
        "    if row[\"CGPA\"]>=6.5:\n",
        "        score+=2\n",
        "\n",
        "    if row[\"Programming\"]>=7:\n",
        "        score+=2\n",
        "\n",
        "    if row[\"Aptitude\"]>=70:\n",
        "        score+=1\n",
        "\n",
        "    if row[\"Communication\"]>=70:\n",
        "        score+=1\n",
        "\n",
        "    if row[\"Projects\"]>=2:\n",
        "        score+=1\n",
        "\n",
        "    if row[\"Internship\"]>=1:\n",
        "        score+=1\n",
        "\n",
        "    if row[\"Certifications\"]>=2:\n",
        "        score+=1\n",
        "\n",
        "    if score>=6:\n",
        "        placement.append(1)\n",
        "    else:\n",
        "        placement.append(0)\n",
        "\n",
        "data[\"Placed\"]=placement\n",
        "\n",
        "data.head()"
      ],
